{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BaseMaster",
  "version": "0.2.0",
  "identifier": "com.basemaster.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BaseMaster",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "dragDropEnabled": false,
        "backgroundColor": "#0a0a0a",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/wilsonglasser/basemaster/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1NzM0MkZFM0RENzA4NEIKUldSTENOYzkva0p6MVZxaGduRXZaZytYdjFRcEtXY0R6ZWxOcU1GTDc0SFlVeFdtMzRLbWRwczAK"
    }
  }
}
